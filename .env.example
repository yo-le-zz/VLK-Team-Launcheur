# VLK Launcher — Server Environment
# Copy to .env and fill in your values

# Database (SQLite default, use PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./vlk.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost/vlk

# Security — CHANGE THESE
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_KEY
MASTER_PASSWORD=your_secure_admin_password_here

# Voice Service: livekit | mumble | webrtc
VOICE_SERVICE=livekit
LIVEKIT_URL=wss://your-livekit-server.com
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
LIVEKIT_ROOM=vlk-main

# Mumble (if using mumble)
MUMBLE_HOST=your.mumble.server
MUMBLE_PORT=64738

# WebRTC (if using Jitsi or custom)
WEBRTC_URL=https://meet.jit.si/vlk-main
